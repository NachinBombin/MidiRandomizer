<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#171614">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Idle"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="8dp"/>

        <!-- Last Note -->
        <TextView
            android:id="@+id/tvLastNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last Note: —"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="16dp"/>

        <!-- MIDI Device List -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIDI Output Device"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <ListView
            android:id="@+id/listViewDevices"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#1C1B19"
            android:layout_marginBottom="16dp"/>

        <!-- Start/Stop -->
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start"
            android:backgroundTint="#01696F"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Voice Style -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Style"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <Spinner
            android:id="@+id/spinnerStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1B19"
            android:layout_marginBottom="16dp"/>

        <!-- BPM -->
        <TextView
            android:id="@+id/tvBpm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BPM: 120"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <SeekBar
            android:id="@+id/seekBpm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="220"
            android:progress="100"
            android:layout_marginBottom="16dp"/>

        <!-- Velocity -->
        <TextView
            android:id="@+id/tvVelocity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Velocity: 64"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <SeekBar
            android:id="@+id/seekVelocity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="126"
            android:progress="63"
            android:layout_marginBottom="16dp"/>

        <!-- Octave Range -->
        <TextView
            android:id="@+id/tvOctave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Octave Range: 3 - 5"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <com.google.android.material.slider.RangeSlider
            android:id="@+id/rangeOctave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="8"
            app:values="@array/default_octave_range"
            android:stepSize="1.0"
            app:minSeparation="0"
            app:thumbColor="#4F9AA5"
            app:trackColorActive="#4F9AA5"
            app:trackColorInactive="#393836"
            android:layout_marginBottom="16dp"/>

        <!-- MIDI Channel -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIDI Channel"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <Spinner
            android:id="@+id/spinnerChannel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1B19"
            android:layout_marginBottom="16dp"/>

        <!-- Scale -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scale"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <Spinner
            android:id="@+id/spinnerScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1C1B19"
            android:layout_marginBottom="16dp"/>

        <!-- Root Note -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Root Note"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>

        <RadioGroup
            android:id="@+id/rgRootRow1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <RadioButton android:id="@+id/rbRootC"  android:tag="0"  android:text="C"  android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootCs" android:tag="1"  android:text="C#" android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootD"  android:tag="2"  android:text="D"  android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootDs" android:tag="3"  android:text="D#" android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootE"  android:tag="4"  android:text="E"  android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootF"  android:tag="5"  android:text="F"  android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
        </RadioGroup>

        <RadioGroup
            android:id="@+id/rgRootRow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <RadioButton android:id="@+id/rbRootFs" android:tag="6"  android:text="F#" android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootG"  android:tag="7"  android:text="G"  android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootGs" android:tag="8"  android:text="G#" android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootA"  android:tag="9"  android:text="A"  android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootAs" android:tag="10" android:text="A#" android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRootB"  android:tag="11" android:text="B"  android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
        </RadioGroup>

        <RadioGroup
            android:id="@+id/rgRootFree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <RadioButton
                android:id="@+id/rbRootFree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free (no root)"
                android:textColor="#CDCCCA"
                android:checked="true"/>
        </RadioGroup>

        <!-- Timing Mode -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timing Mode"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <RadioGroup
            android:id="@+id/rgTiming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <RadioButton android:id="@+id/rbMetronome"  android:text="Metro"    android:textColor="#CDCCCA" android:checked="true" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbMixed"      android:text="Mixed"    android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbRandomized" android:text="Random"   android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            <RadioButton android:id="@+id/rbEuclidean"  android:text="Euclid"   android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
        </RadioGroup>

        <!-- Drone Timing (EVOLVING_DRONE only) -->
        <LinearLayout
            android:id="@+id/layoutDroneTiming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drone Timing"
                android:textColor="#CDCCCA"
                android:layout_marginBottom="4dp"/>
            <RadioGroup
                android:id="@+id/rgDroneTiming"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton android:id="@+id/rbDroneConstant" android:text="Constant" android:textColor="#CDCCCA" android:checked="true" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                <RadioButton android:id="@+id/rbDroneRandom"   android:text="Random"   android:textColor="#CDCCCA" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
            </RadioGroup>
        </LinearLayout>

        <!-- Drone Beat Range (EVOLVING_DRONE + RANDOM only) -->
        <LinearLayout
            android:id="@+id/layoutDroneRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">
            <TextView
                android:id="@+id/tvDroneRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drone beat range: 16 - 64"
                android:textColor="#CDCCCA"
                android:layout_marginBottom="4dp"/>
            <com.google.android.material.slider.RangeSlider
                android:id="@+id/rangeDroneBeats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1"
                android:valueTo="128"
                app:values="@array/default_drone_range"
                android:stepSize="1.0"
                app:thumbColor="#4F9AA5"
                app:trackColorActive="#4F9AA5"
                app:trackColorInactive="#393836"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#171614">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Idle"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="8dp"/>

        <!-- Last Note -->
        <TextView
            android:id="@+id/tvLastNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last Note: —"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="16dp"/>

        <!-- MIDI Device List -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIDI Output Device"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <ListView
            android:id="@+id/listViewDevices"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#1C1B19"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvDeviceInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap a device to connect"
            android:textSize="12sp"
            android:textColor="#797876"
            android:layout_marginBottom="16dp"/>

        <!-- Start/Stop -->
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start"
            android:backgroundTint="#01696F"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Style -->
        <Spinner
            android:id="@+id/spinnerStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- BPM -->
        <TextView
            android:id="@+id/tvBpm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BPM: 120"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <SeekBar
            android:id="@+id/seekBpm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="260"
            android:progress="100"
            android:layout_marginBottom="16dp"/>

        <!-- Velocity -->
        <TextView
            android:id="@+id/tvVelocity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Velocity: 100"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <SeekBar
            android:id="@+id/seekVelocity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="126"
            android:progress="99"
            android:layout_marginBottom="16dp"/>

        <!-- Octave Range -->
        <TextView
            android:id="@+id/tvOctave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Octave: 3 – 5"
            android:textColor="#CDCCCA"
            android:layout_marginBottom="4dp"/>
        <com.google.android.material.slider.RangeSlider
            android:id="@+id/rangeOctave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="8"
            app:values="@array/default_octave_range"
            android:layout_marginBottom="16dp"/>

        <!-- Channel -->
        <Spinner
            android:id="@+id/spinnerChannel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Scale -->
        <Spinner
            android:id="@+id/spinnerScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Root Note Row 1 (C–F) -->
        <RadioGroup
            android:id="@+id/rgRootRow1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <RadioButton android:id="@+id/rbRootC"  android:tag="0"  android:text="C"  android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootCs" android:tag="1"  android:text="C#" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootD"  android:tag="2"  android:text="D"  android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootDs" android:tag="3"  android:text="D#" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootE"  android:tag="4"  android:text="E"  android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootF"  android:tag="5"  android:text="F"  android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
        </RadioGroup>

        <!-- Root Note Row 2 (F#–B) -->
        <RadioGroup
            android:id="@+id/rgRootRow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <RadioButton android:id="@+id/rbRootFs" android:tag="6"  android:text="F#" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootG"  android:tag="7"  android:text="G"  android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootGs" android:tag="8"  android:text="G#" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootA"  android:tag="9"  android:text="A"  android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootAs" android:tag="10" android:text="A#" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRootB"  android:tag="11" android:text="B"  android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
        </RadioGroup>

        <!-- Root FREE -->
        <RadioGroup
            android:id="@+id/rgRootFree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <RadioButton android:id="@+id/rbRootFree" android:text="Free (random)" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
        </RadioGroup>

        <!-- Timing -->
        <RadioGroup
            android:id="@+id/rgTiming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <RadioButton android:id="@+id/rbMetronome"  android:text="Metro"  android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA" android:checked="true"/>
            <RadioButton android:id="@+id/rbMixed"      android:text="Mixed"  android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbRandomized" android:text="Rand"   android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            <RadioButton android:id="@+id/rbEuclidean"  android:text="Eucl"   android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
        </RadioGroup>

        <!-- Drone Timing (Evolving Drone only) -->
        <LinearLayout
            android:id="@+id/layoutDroneTiming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="8dp">
            <RadioGroup
                android:id="@+id/rgDroneTiming"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton android:id="@+id/rbDroneConstant" android:text="Constant" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA" android:checked="true"/>
                <RadioButton android:id="@+id/rbDroneRandom"   android:text="Random"   android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:textColor="#CDCCCA"/>
            </RadioGroup>
        </LinearLayout>

        <!-- Drone Beat Range (Evolving Drone + Random timing only) -->
        <LinearLayout
            android:id="@+id/layoutDroneRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">
            <TextView
                android:id="@+id/tvDroneRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drone beat range: 2 - 8"
                android:textColor="#CDCCCA"
                android:layout_marginBottom="4dp"/>
            <com.google.android.material.slider.RangeSlider
                android:id="@+id/rangeDroneBeats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1"
                android:valueTo="32"
                app:values="@array/default_drone_range"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>

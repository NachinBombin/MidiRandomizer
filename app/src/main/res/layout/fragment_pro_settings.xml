<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_pro_features"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:letterSpacing="0.05"
            android:drawableStart="@drawable/ic_pro_badge"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"/>

        <!-- ═══ TIMING: JITTER ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIMING HUMANIZATION"
            android:textSize="11sp"
            android:textColor="#4F9AA5"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvJitterAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_jitter_amount"
            android:textSize="14sp"
            android:textColor="#E8E6E1"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekJitter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progressTint="#4F9AA5"
            android:thumbTint="#4F9AA5"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jitter distribution"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerJitterType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="24dp"/>

        <!-- ═══ VELOCITY PATTERN ══════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VELOCITY PATTERN"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerVelPattern"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="24dp"/>

        <!-- ═══ MELODIC ENGINE SELECTOR ═══════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MELODIC ENGINE"
            android:textSize="11sp"
            android:textColor="#4F9AA5"
            android:letterSpacing="0.12"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerMelodicEngine"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="16dp"/>

        <!-- ─── MARKOV panel (shown when engine = MARKOV) ──────────────── -->
        <LinearLayout
            android:id="@+id/layoutMarkov"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Markov style" android:textSize="11sp"
                android:textColor="#797876" android:letterSpacing="0.12"
                android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerLogicStyle"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="#1C1B19" android:layout_marginBottom="12dp"/>

            <Switch android:id="@+id/switchSecondOrder"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Second-order chain (direction memory)"
                android:textColor="#E8E6E1" android:textSize="13sp"
                android:thumbTint="#4F9AA5" android:trackTint="#262523"
                android:layout_marginBottom="12dp"/>

            <!-- Narmour IR -->
            <Switch android:id="@+id/switchNarmour"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Narmour IR scoring"
                android:textColor="#E8E6E1" android:textSize="13sp"
                android:thumbTint="#4F9AA5" android:trackTint="#262523"
                android:layout_marginBottom="6dp"/>

            <LinearLayout android:id="@+id/layoutNarmour"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone"
                android:paddingStart="12dp">

                <TextView android:id="@+id/tvNarmourProcess"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Process vs Reversal: 50%" android:textSize="13sp"
                    android:textColor="#E8E6E1" android:layout_marginBottom="4dp"/>
                <SeekBar android:id="@+id/seekNarmourProcess"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="50"
                    android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                    android:layout_marginBottom="10dp"/>

                <TextView android:id="@+id/tvNarmourReturn"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Post-leap return bias: 50%" android:textSize="13sp"
                    android:textColor="#E8E6E1" android:layout_marginBottom="4dp"/>
                <SeekBar android:id="@+id/seekNarmourReturn"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="50"
                    android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                    android:layout_marginBottom="10dp"/>

                <TextView android:id="@+id/tvNarmourLeap"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Leap penalty: 50%" android:textSize="13sp"
                    android:textColor="#E8E6E1" android:layout_marginBottom="4dp"/>
                <SeekBar android:id="@+id/seekNarmourLeap"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="50"
                    android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                    android:layout_marginBottom="4dp"/>
            </LinearLayout>

            <!-- Contour Gravity -->
            <Switch android:id="@+id/switchGravity"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Contour gravity"
                android:textColor="#E8E6E1" android:textSize="13sp"
                android:thumbTint="#4F9AA5" android:trackTint="#262523"
                android:layout_marginTop="8dp" android:layout_marginBottom="6dp"/>

            <LinearLayout android:id="@+id/layoutGravity"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone"
                android:paddingStart="12dp">

                <TextView android:id="@+id/tvGravityThreshold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Threshold: 5 steps" android:textSize="13sp"
                    android:textColor="#E8E6E1" android:layout_marginBottom="4dp"/>
                <SeekBar android:id="@+id/seekGravityThreshold"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="15" android:progress="5"
                    android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                    android:layout_marginBottom="10dp"/>

                <TextView android:id="@+id/tvGravityStrength"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Strength: 3" android:textSize="13sp"
                    android:textColor="#E8E6E1" android:layout_marginBottom="4dp"/>
                <SeekBar android:id="@+id/seekGravityStrength"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="8" android:progress="3"
                    android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                    android:layout_marginBottom="4dp"/>
            </LinearLayout>

            <!-- Gesture Curves -->
            <Switch android:id="@+id/switchGesture"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Gesture curves (Mazzola)"
                android:textColor="#E8E6E1" android:textSize="13sp"
                android:thumbTint="#4F9AA5" android:trackTint="#262523"
                android:layout_marginTop="8dp" android:layout_marginBottom="6dp"/>

            <LinearLayout android:id="@+id/layoutGesture"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:visibility="gone"
                android:paddingStart="12dp">

                <TextView android:id="@+id/tvGestureDepth"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Gesture depth: 0%" android:textSize="13sp"
                    android:textColor="#E8E6E1" android:layout_marginBottom="4dp"/>
                <SeekBar android:id="@+id/seekGestureDepth"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="0"
                    android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                    android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pitch curve" android:textSize="11sp" android:textColor="#797876"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerGesturePitch"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="#1C1B19" android:layout_marginBottom="8dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Register curve" android:textSize="11sp" android:textColor="#797876"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerGestureRegister"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="#1C1B19" android:layout_marginBottom="8dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Density curve" android:textSize="11sp" android:textColor="#797876"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerGestureDensity"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="#1C1B19" android:layout_marginBottom="8dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Velocity curve" android:textSize="11sp" android:textColor="#797876"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerGestureVelocity"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:background="#1C1B19" android:layout_marginBottom="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ─── NRT MELODIC panel ─────────────────────────────────────── -->
        <LinearLayout android:id="@+id/layoutNrtMelodic"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NRT cycle preset" android:textSize="11sp" android:textColor="#797876"
                android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerNrtCycle"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="#1C1B19" android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvNrtPWeight"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="P weight: 1" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekNrtP"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="10" android:progress="5"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvNrtLWeight"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="L weight: 1" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekNrtL"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="10" android:progress="5"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvNrtRWeight"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="R weight: 1" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekNrtR"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="10" android:progress="5"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>

        <!-- ─── PWG panel ──────────────────────────────────────────────── -->
        <LinearLayout android:id="@+id/layoutPwg"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Motif vocabulary" android:textSize="11sp" android:textColor="#797876"
                android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerPwgMotif"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="#1C1B19" android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvPwgPhrase"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Motifs per phrase: 2" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekPwgPhrase"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="7" android:progress="1"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvPwgDirection"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Direction bias: neutral" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekPwgDirection"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="20" android:progress="10"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>

        <!-- ─── L-SYSTEM panel ─────────────────────────────────────────── -->
        <LinearLayout android:id="@+id/layoutLSystem"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="L-System axiom" android:textSize="11sp" android:textColor="#797876"
                android:letterSpacing="0.12" android:layout_marginBottom="6dp"/>
            <Spinner android:id="@+id/spinnerLSystemAxiom"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:background="#1C1B19" android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvLSystemIter"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Iterations: 2" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekLSystemIter"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="3" android:progress="1"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvLSystemVariance"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Rule variance: 10%" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekLSystemVariance"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="100" android:progress="10"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>

        <!-- ─── CELL AUTOMATA panel ────────────────────────────────────── -->
        <LinearLayout android:id="@+id/layoutCellAuto"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:id="@+id/tvCaSurvMin"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Survival min: 1" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekCaSurvMin"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="5" android:progress="1"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvCaSurvMax"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Survival max: 2" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekCaSurvMax"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="5" android:progress="2"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvCaBirth"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Birth count: 2" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekCaBirth"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="5" android:progress="2"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/tvCaMutation"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Mutation rate: 5%" android:textSize="13sp" android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar android:id="@+id/seekCaMutation"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="100" android:progress="5"
                android:progressTint="#4F9AA5" android:thumbTint="#4F9AA5"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>

        <!-- bottom padding -->
        <View android:layout_width="0dp" android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>

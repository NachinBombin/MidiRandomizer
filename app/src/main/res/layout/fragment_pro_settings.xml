<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_pro_features"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:letterSpacing="0.05"
            android:drawableStart="@drawable/ic_pro_badge"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp"/>

        <!-- ═══ TIMING: JITTER ════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIMING HUMANIZATION"
            android:textSize="11sp"
            android:textColor="#4F9AA5"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvJitterAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_jitter_amount"
            android:textSize="14sp"
            android:textColor="#E8E6E1"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekJitter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progressTint="#4F9AA5"
            android:thumbTint="#4F9AA5"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jitter distribution"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerJitterType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="24dp"/>

        <!-- ═══ VELOCITY PATTERN ═══════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VELOCITY PATTERN"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerVelPattern"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="24dp"/>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ═══ PRESETS ═══════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUICK PRESETS"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerPreset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="24dp"/>

        <!-- ═══ TIER 1: JITTER ════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIER 1 — TIMING HUMANISATION"
            android:textSize="11sp"
            android:textColor="#4F9AA5"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvJitterAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jitter: 0 %"
            android:textSize="14sp"
            android:textColor="#E8E6E1"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekJitter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progressTint="#4F9AA5"
            android:thumbTint="#4F9AA5"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JITTER DISTRIBUTION"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerJitterType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="24dp"/>

        <!-- ═══ TIER 1: VELOCITY PATTERN ══════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VELOCITY PATTERN"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerVelPattern"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="24dp"/>

        <!-- ═══ TIER 2: EUCLIDEAN RHYTHM ══════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIER 2 — EUCLIDEAN RHYTHM"
            android:textSize="11sp"
            android:textColor="#4F9AA5"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <Switch
            android:id="@+id/switchEuclidean"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Euclidean Mode"
            android:textColor="#E8E6E1"
            android:textSize="14sp"
            android:thumbTint="#4F9AA5"
            android:trackTint="#262523"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:id="@+id/layoutEuclidean"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvEucSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Steps: 16"
                android:textSize="14sp"
                android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seekEucSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progress="14"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvEucDensity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Density: 5 / 16 pulses"
                android:textSize="14sp"
                android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seekEucDensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="15"
                android:progress="4"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvEucRotation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rotation: 0"
                android:textSize="14sp"
                android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seekEucRotation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="15"
                android:progress="0"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"
                android:layout_marginBottom="12dp"/>

        </LinearLayout>

        <!-- ═══ TIER 2: MARKOV MELODY ═════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIER 2 — MELODIC LOGIC (MARKOV)"
            android:textSize="11sp"
            android:textColor="#4F9AA5"
            android:letterSpacing="0.12"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <Switch
            android:id="@+id/switchMarkov"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Melodic Logic"
            android:textColor="#E8E6E1"
            android:textSize="14sp"
            android:thumbTint="#4F9AA5"
            android:trackTint="#262523"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:id="@+id/layoutMarkov"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOGIC STYLE"
                android:textSize="11sp"
                android:textColor="#797876"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerLogicStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#1C1B19"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

        <!-- bottom padding -->
        <View android:layout_width="0dp" android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>

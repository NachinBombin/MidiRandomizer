<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ── Title row (label + theme button) ─────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MIDI Randomizer"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#E8E6E1"/>

            <Button
                android:id="@+id/btnTheme"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🎨 Theme"
                android:textSize="12sp"
                android:textColor="#E8E6E1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                style="?attr/materialButtonOutlinedStyle"
                app:strokeColor="#393836"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No device connected"
            android:textSize="13sp"
            android:textColor="#4F9AA5"
            android:layout_marginBottom="20dp"/>

        <!-- ── MIDI Devices ───────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIDI DEVICES"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <ListView
            android:id="@+id/listViewDevices"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#1C1B19"
            android:divider="#262523"
            android:dividerHeight="1dp"/>

        <TextView
            android:id="@+id/tvDeviceInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="#797876"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp"/>

        <!-- ── Style ─────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STYLE"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerStyle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvChordHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chord Options at the bottom of the window"
            android:textSize="12sp"
            android:textColor="#FF4444"
            android:textStyle="bold"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- ── Drone Timing (Evolving Drone only) ────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutDroneTiming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DRONE TIMING"
                android:textSize="11sp"
                android:textColor="#797876"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp"/>

            <RadioGroup
                android:id="@+id/rgDroneTiming"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/rbDroneConstant"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Constant"
                    android:textColor="#E8E6E1"
                    android:buttonTint="#4F9AA5"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/rbDroneRandom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Random"
                    android:textColor="#E8E6E1"
                    android:buttonTint="#4F9AA5"/>

            </RadioGroup>

            <LinearLayout
                android:id="@+id/layoutDroneRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvDroneRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drone beat range: 16 - 64"
                    android:textSize="14sp"
                    android:textColor="#E8E6E1"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/rangeDroneBeats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1"
                    android:valueTo="128"
                    app:values="@array/default_drone_range"
                    android:stepSize="1.0"
                    app:thumbColor="#4F9AA5"
                    app:trackColorActive="#4F9AA5"
                    app:trackColorInactive="#393836"
                    android:layout_marginBottom="12dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- ── Scale ─────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCALE"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerScale"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="12dp"/>

        <!-- ── Root Note ──────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ROOT NOTE"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:id="@+id/rootNoteContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <!-- Row 1: C  C#  D  D#  E  F -->
            <RadioGroup
                android:id="@+id/rgRootRow1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <RadioButton android:id="@+id/rbRootC"  style="@style/RootChip" android:text="C"  android:tag="0"/>
                <RadioButton android:id="@+id/rbRootCs" style="@style/RootChip" android:text="C#" android:tag="1"/>
                <RadioButton android:id="@+id/rbRootD"  style="@style/RootChip" android:text="D"  android:tag="2"/>
                <RadioButton android:id="@+id/rbRootDs" style="@style/RootChip" android:text="D#" android:tag="3"/>
                <RadioButton android:id="@+id/rbRootE"  style="@style/RootChip" android:text="E"  android:tag="4"/>
                <RadioButton android:id="@+id/rbRootF"  style="@style/RootChip" android:text="F"  android:tag="5"/>

            </RadioGroup>

            <!-- Row 2: F#  G  G#  A  A#  B -->
            <RadioGroup
                android:id="@+id/rgRootRow2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <RadioButton android:id="@+id/rbRootFs" style="@style/RootChip" android:text="F#" android:tag="6"/>
                <RadioButton android:id="@+id/rbRootG"  style="@style/RootChip" android:text="G"  android:tag="7"/>
                <RadioButton android:id="@+id/rbRootGs" style="@style/RootChip" android:text="G#" android:tag="8"/>
                <RadioButton android:id="@+id/rbRootA"  style="@style/RootChip" android:text="A"  android:tag="9"/>
                <RadioButton android:id="@+id/rbRootAs" style="@style/RootChip" android:text="A#" android:tag="10"/>
                <RadioButton android:id="@+id/rbRootB"  style="@style/RootChip" android:text="B"  android:tag="11"/>

            </RadioGroup>

            <!-- FREE row -->
            <RadioGroup
                android:id="@+id/rgRootFree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbRootFree"
                    style="@style/RootChip"
                    android:text="FREE  (no root)"
                    android:layout_width="match_parent"
                    android:checked="true"
                    android:tag="-1"/>

            </RadioGroup>

        </LinearLayout>

        <!-- ── BPM ───────────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvBpm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BPM: 120"
            android:textSize="14sp"
            android:textColor="#E8E6E1"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekBpm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="280"
            android:progressTint="#4F9AA5"
            android:thumbTint="#4F9AA5"
            android:layout_marginBottom="16dp"/>

        <!-- ── Velocity ──────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvVelocity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Velocity: 100"
            android:textSize="14sp"
            android:textColor="#E8E6E1"
            android:layout_marginBottom="4dp"/>

        <SeekBar
            android:id="@+id/seekVelocity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="126"
            android:progressTint="#4F9AA5"
            android:thumbTint="#4F9AA5"
            android:layout_marginBottom="16dp"/>

        <!-- ── Octave range ──────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvOctave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Octave range: 3 - 5"
            android:textSize="14sp"
            android:textColor="#E8E6E1"
            android:layout_marginBottom="4dp"/>

        <com.google.android.material.slider.RangeSlider
            android:id="@+id/rangeOctave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="8"
            app:values="@array/default_octave_range"
            android:stepSize="1.0"
            app:thumbColor="#4F9AA5"
            app:trackColorActive="#4F9AA5"
            app:trackColorInactive="#393836"
            android:layout_marginBottom="16dp"/>

        <!-- ── MIDI Channel ───────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIDI CHANNEL"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerChannel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#1C1B19"
            android:layout_marginBottom="16dp"/>

        <!-- ── Timing mode ────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TIMING MODE"
            android:textSize="11sp"
            android:textColor="#797876"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <RadioGroup
            android:id="@+id/rgTiming"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <RadioButton
                android:id="@+id/rbMetronome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Metro"
                android:textColor="#E8E6E1"
                android:buttonTint="#4F9AA5"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rbMixed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mixed"
                android:textColor="#E8E6E1"
                android:buttonTint="#4F9AA5"/>

            <RadioButton
                android:id="@+id/rbRandomized"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Random"
                android:textColor="#E8E6E1"
                android:buttonTint="#4F9AA5"/>

            <RadioButton
                android:id="@+id/rbEuclidean"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Eucl."
                android:textColor="#E8E6E1"
                android:buttonTint="#4F9AA5"/>

        </RadioGroup>

        <!-- ── Euclidean Settings (Compact) ── -->
        <LinearLayout
            android:id="@+id/layoutEuclideanSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1C1B19"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvEuclideanSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Steps: 16"
                android:textSize="12sp"
                android:textColor="#CDCCCA"/>
            <SeekBar
                android:id="@+id/seekEuclideanSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progress="14"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"/>

            <TextView
                android:id="@+id/tvEuclideanDensity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Density: 4"
                android:textSize="12sp"
                android:textColor="#CDCCCA"
                android:layout_marginTop="4dp"/>
            <SeekBar
                android:id="@+id/seekEuclideanDensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="32"
                android:progress="4"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"/>

            <TextView
                android:id="@+id/tvEuclideanRotation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rotation: 0"
                android:textSize="12sp"
                android:textColor="#CDCCCA"
                android:layout_marginTop="4dp"/>
            <SeekBar
                android:id="@+id/seekEuclideanRotation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="32"
                android:progress="0"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"/>
        </LinearLayout>

        <!-- ── Last note display ─────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvLastNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last note: -"
            android:textSize="15sp"
            android:textColor="#6DAA45"
            android:layout_marginBottom="20dp"/>

        <!-- ── Start / Stop ──────────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="START"
            android:textSize="16sp"
            android:textColor="#F7F6F2"
            android:backgroundTint="#01696F"
            android:layout_marginBottom="8dp"/>

        <!-- ════════════════════════════════════════════════════════════════
             CHORD SETTINGS PANEL  (visible only when Style = Chords)
             ════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutChordSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="20dp"
            android:background="#1C1B19"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHORD SETTINGS"
                android:textSize="11sp"
                android:textColor="#797876"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"/>

            <!-- Chord Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chord type"
                android:textSize="12sp"
                android:textColor="#CDCCCA"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinnerChordType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#262523"
                android:layout_marginBottom="12dp"/>

            <!-- Build Strategy -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Build strategy"
                android:textSize="12sp"
                android:textColor="#CDCCCA"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinnerBuildStrategy"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#262523"
                android:layout_marginBottom="12dp"/>

            <!-- Inversion Mode -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inversion"
                android:textSize="12sp"
                android:textColor="#CDCCCA"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinnerInversionMode"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#262523"
                android:layout_marginBottom="12dp"/>

            <!-- Voicing Density -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voicing density"
                android:textSize="12sp"
                android:textColor="#CDCCCA"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinnerVoicingDensity"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#262523"
                android:layout_marginBottom="12dp"/>

            <!-- Plucking Style -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plucking style"
                android:textSize="12sp"
                android:textColor="#CDCCCA"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinnerPluckingStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#262523"
                android:layout_marginBottom="12dp"/>

            <!-- Rhythmic Figure -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rhythmic figure"
                android:textSize="12sp"
                android:textColor="#CDCCCA"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinnerRhythmicFigure"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#262523"
                android:layout_marginBottom="12dp"/>

            <!-- Pluck Delay -->
            <TextView
                android:id="@+id/tvPluckDelay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pluck delay: 20 ms"
                android:textSize="13sp"
                android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar
                android:id="@+id/seekPluckDelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="99"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"
                android:layout_marginBottom="12dp"/>

            <!-- Tension Level -->
            <TextView
                android:id="@+id/tvTensionLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tension: Triad"
                android:textSize="13sp"
                android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar
                android:id="@+id/seekTensionLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="3"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"
                android:layout_marginBottom="12dp"/>

            <!-- Mutation Chance -->
            <TextView
                android:id="@+id/tvMutationChance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mutation: 0%"
                android:textSize="13sp"
                android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar
                android:id="@+id/seekMutationChance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="30"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"
                android:layout_marginBottom="12dp"/>

            <!-- Note Drop Chance -->
            <TextView
                android:id="@+id/tvNoteDropChance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Note drop: 0%"
                android:textSize="13sp"
                android:textColor="#E8E6E1"
                android:layout_marginBottom="4dp"/>
            <SeekBar
                android:id="@+id/seekNoteDropChance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="50"
                android:progressTint="#4F9AA5"
                android:thumbTint="#4F9AA5"
                android:layout_marginBottom="4dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
